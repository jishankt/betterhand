DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=betterhand_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase (get from Firebase Console > Project Settings > Service Accounts)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# OpenRouteService (get from openrouteservice.org)
ORS_API_KEY=your-ors-api-key-here

# Email (Gmail App Password)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Donor cooldown in days
DONOR_COOLDOWN_DAYS=90

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
